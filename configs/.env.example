# Global Environment Variables Example
# Duplicate this to .env and fill in values for local development.

# --- INFRASTRUCTURE (Docker required) ---
DB_HOST=localhost
DB_PORT=5433
DB_USER=admin
DB_PASSWORD=password123
REDIS_ADDR=127.0.0.1:6379

# --- NEXT.JS FRONTEND (Port 3000) ---
NEXT_PUBLIC_ORCH_URL=http://localhost:8080

# --- GO ORCHESTRATOR (Port 8080) ---
JWT_SECRET=your-secure-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GITHUB_CLIENT_ID=your-github-client-id

# --- PYTHON AGENT ENGINE (Port 8000) ---
GOOGLE_API_KEY=your-gemini-pro-api-key
AGENT_SIGNAL_URL=http://localhost:8080/api/v1/internal/progress
